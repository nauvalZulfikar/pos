# DESAIN POS — environment variables
# Copy to .env (root) and fill in for local dev. Never commit .env.

NODE_ENV=development

# --- Database ---
DATABASE_URL=postgres://desain:desain@localhost:5432/desain_pos
DATABASE_ADMIN_URL=postgres://desain_admin:desain_admin@localhost:5432/desain_pos

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3000
API_BASE_URL=http://localhost:3000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3002

# --- Auth ---
SESSION_SECRET=replace-me-min-32-chars-of-random-bytes-please
TERMINAL_TOKEN_SECRET=replace-me-different-32-char-secret-also

# --- Apps ---
POS_PORT=5173
ADMIN_PORT=3001
MARKETING_PORT=3002
ML_PORT=8000
WORKER_METRICS_PORT=9091

# --- Object storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=desain-pos-dev
R2_PUBLIC_URL_BASE=

# --- Payment (Midtrans) ---
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_WEBHOOK_SECRET=

# --- Payment fallback (Xendit) ---
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# --- Delivery platforms ---
GOFOOD_CLIENT_ID=
GOFOOD_CLIENT_SECRET=
GOFOOD_WEBHOOK_SECRET=
GRABFOOD_PARTNER_ID=
GRABFOOD_PARTNER_SECRET=
GRABFOOD_WEBHOOK_SECRET=
SHOPEEFOOD_PARTNER_ID=
SHOPEEFOOD_PARTNER_KEY=
SHOPEEFOOD_WEBHOOK_SECRET=

# --- WhatsApp Business (Meta) ---
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=
WA_WEBHOOK_VERIFY_TOKEN=

# --- LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_DAILY_BRIEF_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MENU_SCORE_MODEL=claude-sonnet-4-6

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=DESAIN POS <noreply@desain.id>

# --- Observability ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=desain-pos

# --- ML service ---
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_JWT_SECRET=replace-me-shared-with-ml-service
