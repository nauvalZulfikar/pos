{
  "name": "@desain/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./tenant-context": "./src/tenant-context.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "migrate": "tsx src/migrate.ts",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push",
    "reset": "node scripts/reset.mjs",
    "seed": "tsx src/seed/run.ts",
    "studio": "drizzle-kit studio",
    "rls:apply": "tsx src/rls/apply.ts"
  },
  "dependencies": {
    "@desain/domain": "workspace:*",
    "@desain/types": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@desain/config": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
