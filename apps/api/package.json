{
  "name": "@desain/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit && echo \"[api] typecheck only — runtime uses tsx (workspace packages export TS source)\"",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "openapi:generate": "tsx src/openapi.ts > openapi.json"
  },
  "dependencies": {
    "@desain/db": "workspace:*",
    "@desain/domain": "workspace:*",
    "@desain/integrations": "workspace:*",
    "@desain/sync": "workspace:*",
    "@desain/types": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.3",
    "@scalar/hono-api-reference": "^0.5.165",
    "argon2": "^0.41.1",
    "bullmq": "^5.25.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.10",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "uuidv7": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@desain/config": "workspace:*",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
